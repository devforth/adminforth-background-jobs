{
  "name": "@adminforth/background-jobs",
  "version": "1.0.1",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "type": "module",
  "homepage": "https://adminforth.dev/docs/tutorial/Plugins/background-jobs/",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc && rsync -av --exclude 'node_modules' custom dist/"
  },
  "keywords": [
    "adminforth",
    "background-jobs",
    "async-processing",
    "task-runner",
    "job-management",
    "progress-tracking",
    "long-running-tasks"
  ],
  "author": "DevForth (https://devforth.io)",
  "license": "MIT",
  "description": "Background jobs plugin for AdminForth to run and manage long tasks from resources",
  "devDependencies": {
    "@types/node": "latest",
    "adminforth": "^2.42.0",
    "semantic-release": "^24.2.1",
    "semantic-release-slack-bot": "^4.0.2",
    "typescript": "^5.7.3"
  },
  "release": {
    "plugins": [
      [
        "semantic-release-slack-bot",
        "@semantic-release/commit-analyzer",
        "@semantic-release/release-notes-generator",
        "@semantic-release/npm",
        "@semantic-release/github",
        {
          "packageName": "@adminforth/background-jobs",
          "notifyOnSuccess": true,
          "notifyOnFail": true,
          "slackIcon": ":package:",
          "markdownReleaseNotes": true
        }
      ]
    ]
  },
  "dependencies": {
    "@vueuse/core": "^14.2.1",
    "async-mutex": "^0.5.0",
    "level": "^10.0.0",
    "p-limit": "^7.3.0"
  },
  "peerDependencies": {
    "adminforth": "^2.42.0"
  }
}
